# ============================================
# Howners — Local Development Environment Variables
# ============================================
# Copy this file to .env and adjust values as needed.
# NEVER commit .env to version control.

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=dev

# --- Database ---
POSTGRES_DB=howners_db
POSTGRES_USER=howners_user
POSTGRES_PASSWORD=howners_pass
DATABASE_URL=jdbc:postgresql://localhost:5432/howners_db

# --- JWT Authentication ---
JWT_SECRET=your-secret-key-here-change-in-production-min-64-chars-recommended
JWT_EXPIRATION=86400000      # 24 hours in milliseconds

# --- MinIO / S3 Storage ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=howners-documents

# --- SMTP Email ---
# Local dev uses MailHog (docker-compose service on port 1025).
# Set SMTP_AUTH=false and SMTP_STARTTLS=false for MailHog.
# Web UI to read captured emails: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
EMAIL_FROM=noreply@howners.com

# --- Stripe Configuration (test keys) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=2.5

# --- E-Signature Provider ---
ESIGNATURE_PROVIDER=docusign   # docusign, hellosign, etc.

# --- DocuSign E-Signature (optional, demo environment) ---
# Without these, the DocuSign envelope flow will fail but
# the in-app canvas signature path still works.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE_PATH=https://account-d.docusign.com
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_IMPERSONATED_USER_GUID=
DOCUSIGN_WEBHOOK_SECRET=

# --- YouSign (legacy, kept for backward compat) ---
YOUSIGN_API_KEY=your-yousign-api-key

# --- SendGrid (legacy email provider) ---
SENDGRID_API_KEY=your-sendgrid-api-key

# --- Application URLs ---
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201
