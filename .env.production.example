# ============================================
# Howners — Production Environment Variables
# ============================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.

# --- Database ---
POSTGRES_DB=howners_db
POSTGRES_USER=howners_user
POSTGRES_PASSWORD=           # REQUIRED: Strong password (min 16 chars)
DATABASE_URL=jdbc:postgresql://postgres:5432/howners_db

# --- JWT Authentication ---
JWT_SECRET=                  # REQUIRED: Random string, min 64 chars. Generate with: openssl rand -base64 64
JWT_EXPIRATION=86400000      # 24 hours in milliseconds

# --- MinIO / S3 Storage ---
MINIO_ROOT_USER=             # REQUIRED: MinIO admin username
MINIO_ROOT_PASSWORD=         # REQUIRED: MinIO admin password (min 8 chars)
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=howners-documents

# --- SMTP Email ---
SMTP_HOST=smtp.gmail.com     # Or your SMTP provider
SMTP_PORT=587
SMTP_USERNAME=               # REQUIRED: SMTP login
SMTP_PASSWORD=               # REQUIRED: SMTP password or app password
SMTP_AUTH=true
SMTP_STARTTLS=true
EMAIL_FROM=noreply@howners.com

# --- Stripe Payments ---
STRIPE_SECRET_KEY=           # REQUIRED for payments
STRIPE_PUBLIC_KEY=           # REQUIRED for payments
STRIPE_WEBHOOK_SECRET=       # REQUIRED for webhooks
STRIPE_PLATFORM_FEE_PERCENT=2.5

# --- DocuSign E-Signature (optional) ---
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://www.docusign.net/restapi
DOCUSIGN_OAUTH_BASE_PATH=https://account.docusign.com
DOCUSIGN_PRIVATE_KEY=        # PEM format, newlines replaced with \n
DOCUSIGN_IMPERSONATED_USER_GUID=
DOCUSIGN_WEBHOOK_SECRET=

# --- Application URLs ---
BACKEND_URL=https://api.howners.com
FRONTEND_URL=https://app.howners.com
CORS_ALLOWED_ORIGINS=https://app.howners.com

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=prod
