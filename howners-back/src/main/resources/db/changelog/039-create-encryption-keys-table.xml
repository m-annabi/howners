<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="039-1" author="howners">
        <comment>Create encryption_keys table for document encryption key management</comment>

        <createTable tableName="encryption_keys">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="key_alias" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="encrypted_key" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="algorithm" type="VARCHAR(50)" defaultValue="AES-256-GCM">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="rotated_at" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex tableName="encryption_keys" indexName="idx_encryption_keys_alias">
            <column name="key_alias"/>
        </createIndex>
        <createIndex tableName="encryption_keys" indexName="idx_encryption_keys_active">
            <column name="active"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
