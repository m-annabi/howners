<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="052-1" author="howners">
        <addColumn tableName="rentals">
            <column name="application_id" type="UUID">
                <constraints nullable="true" unique="true"
                             uniqueConstraintName="uk_rentals_application"
                             foreignKeyName="fk_rentals_application"
                             references="applications(id)"/>
            </column>
        </addColumn>

        <createIndex tableName="rentals" indexName="idx_rentals_application">
            <column name="application_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
