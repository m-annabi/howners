<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.28.xsd">

    <changeSet id="072-1" author="claude">
        <comment>Révisions annuelles de loyer indexées sur l'IRL</comment>
        <createTable tableName="rent_revisions">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="rental_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_revision_rental" references="rentals(id)"/>
            </column>
            <column name="ancien_loyer" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="nouveau_loyer" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="indice_ancien_id" type="UUID">
                <constraints foreignKeyName="fk_revision_indice_ancien" references="irl_indices(id)"/>
            </column>
            <column name="indice_nouveau_id" type="UUID">
                <constraints foreignKeyName="fk_revision_indice_nouveau" references="irl_indices(id)"/>
            </column>
            <column name="date_revision" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="date_effet" type="DATE"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="BROUILLON">
                <constraints nullable="false"/>
            </column>
            <column name="document_id" type="UUID">
                <constraints foreignKeyName="fk_revision_document" references="documents(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <createIndex tableName="rent_revisions" indexName="idx_revision_rental">
            <column name="rental_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
