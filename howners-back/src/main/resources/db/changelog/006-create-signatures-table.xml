<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-create-signatures-table" author="howners">
        <createTable tableName="signatures">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="document_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_signatures_document" references="documents(id)"/>
            </column>
            <column name="contract_id" type="UUID">
                <constraints foreignKeyName="fk_signatures_contract" references="contracts(id)"/>
            </column>
            <column name="signer_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_signatures_signer" references="users(id)"/>
            </column>
            <column name="signature_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="provider" type="VARCHAR(50)"/>
            <column name="provider_signature_id" type="VARCHAR(255)"/>
            <column name="signature_data" type="TEXT"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="user_agent" type="TEXT"/>
            <column name="signed_at" type="TIMESTAMP"/>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createIndex indexName="idx_signatures_document" tableName="signatures">
            <column name="document_id"/>
        </createIndex>
        <createIndex indexName="idx_signatures_contract" tableName="signatures">
            <column name="contract_id"/>
        </createIndex>
        <createIndex indexName="idx_signatures_signer" tableName="signatures">
            <column name="signer_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
