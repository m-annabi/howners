<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.28.xsd">

    <changeSet id="079-drop-discovery-rating-tables" author="howners">
        <!-- tenant_invitations dépend de tenant_search_profiles, doit être droppée en premier -->
        <!-- onFail="MARK_RAN" : si les tables ont déjà été supprimées manuellement, on passe -->
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tenant_invitations"/>
        </preConditions>
        <dropTable tableName="tenant_invitations" cascadeConstraints="true"/>
        <dropTable tableName="tenant_search_profiles" cascadeConstraints="true"/>
        <dropTable tableName="tenant_ratings" cascadeConstraints="true"/>
    </changeSet>

</databaseChangeLog>
