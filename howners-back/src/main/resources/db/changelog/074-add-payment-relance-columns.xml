<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.28.xsd">

    <changeSet id="074-1" author="claude">
        <comment>Escalade des relances d'impayés (0 = aucune, 1 = relance J+5, 2 = mise en demeure J+15)</comment>
        <addColumn tableName="payments">
            <column name="relance_niveau" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="derniere_relance_le" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
