<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="033-create-etat-des-lieux-table" author="howners">
        <createTable tableName="etat_des_lieux">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="rental_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_edl_rental" references="rentals(id)"/>
            </column>
            <column name="type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="inspection_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="room_conditions" type="JSONB"/>
            <column name="meter_readings" type="JSONB"/>
            <column name="keys_count" type="INT"/>
            <column name="keys_description" type="TEXT"/>
            <column name="general_comments" type="TEXT"/>
            <column name="owner_signed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="tenant_signed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="owner_signed_at" type="TIMESTAMP"/>
            <column name="tenant_signed_at" type="TIMESTAMP"/>
            <column name="document_id" type="UUID">
                <constraints foreignKeyName="fk_edl_document" references="documents(id)"/>
            </column>
            <column name="created_by" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_edl_created_by" references="users(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createIndex indexName="idx_edl_rental" tableName="etat_des_lieux">
            <column name="rental_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
