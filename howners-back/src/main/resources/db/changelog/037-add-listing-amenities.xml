<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="037-1" author="howners">
        <comment>Add amenities, requirements and available_from to listings</comment>

        <addColumn tableName="listings">
            <column name="amenities" type="JSONB"/>
        </addColumn>

        <addColumn tableName="listings">
            <column name="requirements" type="JSONB"/>
        </addColumn>

        <addColumn tableName="listings">
            <column name="available_from" type="DATE"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
