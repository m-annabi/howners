<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="014-add-document-improvements" author="howners">

        <!-- Ajouter la colonne file_key -->
        <addColumn tableName="documents">
            <column name="file_key" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Ajouter la colonne description -->
        <addColumn tableName="documents">
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Migrer les données existantes: extraire file_key de file_path -->
        <sql>
            UPDATE documents
            SET file_key = file_path
            WHERE file_key IS NULL AND file_path IS NOT NULL;
        </sql>

        <!-- Rendre file_key NOT NULL après migration -->
        <addNotNullConstraint
            tableName="documents"
            columnName="file_key"
            columnDataType="VARCHAR(500)"/>

        <!-- Créer un index sur file_key pour performance -->
        <createIndex indexName="idx_documents_file_key" tableName="documents">
            <column name="file_key"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
