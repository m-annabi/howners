<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.28.xsd">

    <changeSet id="060-add-stripe-connect-fields" author="howners">
        <comment>Stripe Connect Express account id + onboarding state. The platform fee + payments routing logic lives in code; this column is the link key.</comment>
        <addColumn tableName="users">
            <column name="stripe_connect_account_id" type="VARCHAR(255)"/>
            <column name="stripe_connect_status" type="VARCHAR(40)" defaultValue="NONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="users" columnName="stripe_connect_status"/>
            <dropColumn tableName="users" columnName="stripe_connect_account_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
