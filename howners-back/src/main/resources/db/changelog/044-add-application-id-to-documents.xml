<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="044-add-application-id-to-documents" author="howners">
        <addColumn tableName="documents">
            <column name="application_id" type="UUID"/>
        </addColumn>

        <addForeignKeyConstraint
            baseTableName="documents"
            baseColumnNames="application_id"
            constraintName="fk_documents_application"
            referencedTableName="applications"
            referencedColumnNames="id"/>

        <createIndex tableName="documents" indexName="idx_documents_application_id">
            <column name="application_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
