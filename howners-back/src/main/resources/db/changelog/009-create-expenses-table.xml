<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="009-create-expenses-table" author="howners">
        <createTable tableName="expenses">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="property_id" type="UUID">
                <constraints foreignKeyName="fk_expenses_property" references="properties(id)"/>
            </column>
            <column name="rental_id" type="UUID">
                <constraints foreignKeyName="fk_expenses_rental" references="rentals(id)"/>
            </column>
            <column name="category" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="amount" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)" defaultValue="EUR"/>
            <column name="expense_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="document_id" type="UUID">
                <constraints foreignKeyName="fk_expenses_document" references="documents(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createIndex indexName="idx_expenses_property" tableName="expenses">
            <column name="property_id"/>
        </createIndex>
        <createIndex indexName="idx_expenses_rental" tableName="expenses">
            <column name="rental_id"/>
        </createIndex>
        <createIndex indexName="idx_expenses_category" tableName="expenses">
            <column name="category"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
