<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="047-create-tenant-invitations-table" author="howners">
        <createTable tableName="tenant_invitations">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="listing_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_tenant_invitations_listing" references="listings(id)"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_tenant_invitations_tenant" references="users(id)"/>
            </column>
            <column name="owner_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_tenant_invitations_owner" references="users(id)"/>
            </column>
            <column name="message" type="TEXT"/>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <addUniqueConstraint tableName="tenant_invitations"
                             columnNames="listing_id, tenant_id"
                             constraintName="uk_tenant_invitations_listing_tenant"/>

        <createIndex indexName="idx_tenant_invitations_tenant" tableName="tenant_invitations">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_tenant_invitations_listing" tableName="tenant_invitations">
            <column name="listing_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
