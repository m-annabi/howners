<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-rentals-table" author="howners">
        <createTable tableName="rentals">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="property_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_rentals_property" references="properties(id)"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints foreignKeyName="fk_rentals_tenant" references="users(id)"/>
            </column>
            <column name="rental_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE"/>
            <column name="monthly_rent" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)" defaultValue="EUR"/>
            <column name="deposit_amount" type="DECIMAL(10,2)"/>
            <column name="charges" type="DECIMAL(10,2)"/>
            <column name="payment_day" type="INT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createIndex indexName="idx_rentals_property" tableName="rentals">
            <column name="property_id"/>
        </createIndex>
        <createIndex indexName="idx_rentals_tenant" tableName="rentals">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_rentals_status" tableName="rentals">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
