<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="035-1" author="howners">
        <comment>Create applications table for listing candidatures</comment>

        <createTable tableName="applications">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="listing_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_applications_listing" references="listings(id)"/>
            </column>
            <column name="applicant_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_applications_applicant" references="users(id)"/>
            </column>
            <column name="cover_letter" type="TEXT"/>
            <column name="desired_move_in" type="DATE"/>
            <column name="status" type="VARCHAR(20)" defaultValue="SUBMITTED">
                <constraints nullable="false"/>
            </column>
            <column name="reviewed_at" type="TIMESTAMP"/>
            <column name="reviewed_by" type="UUID">
                <constraints foreignKeyName="fk_applications_reviewer" references="users(id)"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createIndex indexName="idx_applications_listing" tableName="applications">
            <column name="listing_id"/>
        </createIndex>
        <createIndex indexName="idx_applications_applicant" tableName="applications">
            <column name="applicant_id"/>
        </createIndex>
        <createIndex indexName="idx_applications_status" tableName="applications">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
