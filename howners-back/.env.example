# Howners backend — copier ce fichier en `.env` et remplir vos valeurs.
# Ce fichier .env.example est versionné ; .env est dans .gitignore.

# ---- SMTP -----------------------------------------------------------------
# Local (MailHog) : SMTP_HOST=localhost, SMTP_PORT=1025, SMTP_AUTH=false, SMTP_STARTTLS=false
# Prod (Gmail SMTP example) : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_AUTH=true, SMTP_STARTTLS=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
EMAIL_FROM=noreply@howners.local
EMAIL_FROM_NAME=Howners

# ---- Database (overrides application.yml defaults) ------------------------
# DATABASE_URL=jdbc:postgresql://localhost:5432/howners_db
# POSTGRES_USER=howners_user
# POSTGRES_PASSWORD=howners_pass

# ---- JWT ------------------------------------------------------------------
# Générer ex : openssl rand -base64 64
JWT_SECRET=replace-with-a-64-byte-random-secret
JWT_EXPIRATION=86400000

# ---- MinIO / S3 -----------------------------------------------------------
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=howners-documents

# ---- DocuSign (laisser vide pour utiliser le provider canvas interne) -----
# ESIGNATURE_PROVIDER=internal | docusign
ESIGNATURE_PROVIDER=internal
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_IMPERSONATED_USER_GUID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE_PATH=https://account-d.docusign.com
DOCUSIGN_WEBHOOK_SECRET=
# Si vous activez DocuSign, mettre la PEM sur UNE ligne en remplaçant les \n par \\n,
# ou utiliser docker secrets / Spring Cloud Config en prod.
DOCUSIGN_PRIVATE_KEY=

# ---- Stripe (subscriptions + Connect) -------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- OpenAI (assistant IA bail) -------------------------------------------
# Laissez vide pour utiliser le mock draft.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- URLs de l'app --------------------------------------------------------
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:4200

# ---- CORS -----------------------------------------------------------------
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200
